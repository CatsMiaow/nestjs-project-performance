{
  "name": "nestjs-project-performance",
  "version": "0.0.0",
  "description": "Node.js framework NestJS project for performance",
  "license": "MIT",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "lint": "eslint",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "build": "nest build",
    "start": "node dist/app",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "test": "vitest run --exclude **/e2e/**/*.ts",
    "test:e2e": "vitest run --config ./test/vitest.e2e.ts",
    "esm": "node --import @swc-node/register/esm-register",
    "entity:load": "npm run esm ./bin/entities.ts",
    "entity:sync": "npm run esm ./bin/synchronize.ts",
    "doc:api": "nest build && node dist/swagger"
  },
  "dependencies": {
    "@fastify/compress": "^8.3.1",
    "@fastify/cookie": "^11.0.2",
    "@fastify/helmet": "^13.0.2",
    "@fastify/passport": "^3.0.2",
    "@fastify/session": "^11.1.1",
    "@fastify/static": "^8.3.0",
    "@mikro-orm/core": "^7.0.2",
    "@mikro-orm/decorators": "^7.0.2",
    "@mikro-orm/mysql": "^7.0.2",
    "@mikro-orm/nestjs": "^7.0.1",
    "@nestjs/common": "^11.1.16",
    "@nestjs/config": "4.0.3",
    "@nestjs/core": "^11.1.16",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-fastify": "^11.1.16",
    "@nestjs/serve-static": "^5.0.4",
    "@nestjs/swagger": "^11.2.6",
    "@nestjs/terminus": "^11.1.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.4",
    "nestjs-pino": "^4.6.1",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "passport-local": "^1.0.0",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@inquirer/prompts": "^8.3.0",
    "@mikro-orm/cli": "^7.0.2",
    "@mikro-orm/entity-generator": "^7.0.2",
    "@nestjs/cli": "^11.0.16",
    "@nestjs/testing": "^11.1.16",
    "@swc-node/register": "^1.11.1",
    "@swc/cli": "^0.7.10",
    "@swc/core": "^1.15.18",
    "@types/node": "^24.12.0",
    "@types/passport-jwt": "^4.0.1",
    "@types/passport-local": "^1.0.38",
    "@types/supertest": "^7.2.0",
    "@vitest/eslint-plugin": "^1.6.12",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-sonarjs": "^4.0.2",
    "neostandard": "^0.13.0",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.8.1",
    "supertest": "^7.2.2",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.0",
    "vitest": "^4.1.0",
    "vitest-mock-extended": "^3.1.0"
  }
}
